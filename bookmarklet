javascript:(()=>{const seen=new Map();const yearRe=/\b(19|20)\d{2}\b/;document.querySelectorAll('a[href*="/title/tt"]').forEach(a=>{const m=a.href.match(/\/title\/(tt\d+)/);if(!m)return;const id=m[1];const row=a.closest('[data-testid],li,article,section,div');const ctx=(row?.innerText||a.parentElement?.innerText||'').replace(/\s+/g,' ').trim();let title=(a.innerText||a.textContent||'').trim().replace(/^\d+\.\s*/,'');if(!title||title.length<2)return;if(title.toLowerCase().includes('episode'))return;title=title.replace(/\s*\((?:19|20)\d{2}\)\s*$/,'').trim();let y='';const titleYear=(a.innerText||'').match(/\((19|20)\d{2}\)/);if(titleYear)y=titleYear[0].replace(/[()]/g,'');else{const rowYear=ctx.match(yearRe);if(rowYear)y=rowYear[0];}if(!seen.has(id))seen.set(id,{title,imdb_title_id:id,year:y,url:`https://www.imdb.com/title/${id}/`});});const data=[...seen.values()];const blob=new Blob([JSON.stringify(data,null,2)],{type:'application/json'});const url=URL.createObjectURL(blob);const link=document.createElement('a');link.href=url;link.download='imdb_titles.json';link.click();URL.revokeObjectURL(url);alert(`Poster Montage Designer exported ${data.length} titles.`);})();